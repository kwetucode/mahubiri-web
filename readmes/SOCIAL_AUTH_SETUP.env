# ==================================
# CONFIGURATION AUTHENTIFICATION SOCIALE
# ==================================

# Ce fichier contient les instructions pour configurer l'authentification
# sociale avec Google et Facebook pour votre API Laravel + Flutter

# ----------------------------------
# ÉTAPE 1: Configuration Google
# ----------------------------------

# 1. Allez sur: https://console.cloud.google.com/
# 2. Créez un nouveau projet ou sélectionnez-en un existant
# 3. Activez l'API "Google+ API"
# 4. Créez des identifiants OAuth 2.0:
#    - Type: Application Web
#    - Origines JavaScript autorisées: http://localhost:8000
#    - URI de redirection: http://localhost:8000/auth/google/callback
# 5. Pour Flutter, ajoutez aussi un client OAuth pour:
#    - Android (avec SHA-1 de votre keystore)
#    - iOS (avec Bundle ID)
# 6. Copiez Client ID et Client Secret ci-dessous:

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ----------------------------------
# ÉTAPE 2: Configuration Facebook
# ----------------------------------

# 1. Allez sur: https://developers.facebook.com/
# 2. Créez une nouvelle application
# 3. Ajoutez le produit "Facebook Login":
#    - Type: Consumer
#    - Plateforme: iOS et Android
# 4. Configuration du produit:
#    - URI de redirection OAuth valides: http://localhost:8000/auth/facebook/callback
# 5. Paramètres de l'application:
#    - Ajoutez vos Package Name (Android) et Bundle ID (iOS)
#    - Key Hashes pour Android
# 6. Obtenez l'App ID et l'App Secret:
#    - Paramètres > Élémentaires
# 7. Copiez App ID et App Secret ci-dessous:

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# ----------------------------------
# ÉTAPE 3: Configuration Flutter
# ----------------------------------

# Android - strings.xml
# <string name="facebook_app_id">VOTRE_FACEBOOK_APP_ID</string>
# <string name="fb_login_protocol_scheme">fbVOTRE_FACEBOOK_APP_ID</string>
# <string name="facebook_client_token">VOTRE_CLIENT_TOKEN</string>

# iOS - Info.plist (Google)
# <string>com.googleusercontent.apps.VOTRE-CLIENT-ID</string>

# iOS - Info.plist (Facebook)
# <key>FacebookAppID</key>
# <string>VOTRE_FACEBOOK_APP_ID</string>

# ----------------------------------
# NOTES IMPORTANTES
# ----------------------------------

# - Pour PRODUCTION, changez les URLs de redirection
# - Activez les domaines de votre site dans les consoles Google/Facebook
# - N'oubliez pas de configurer les SHA-1/SHA-256 pour Android
# - Testez avec des comptes de test avant de publier
# - Les tokens sociaux expirent (généralement après 60 jours)

# ----------------------------------
# TESTER LA CONFIGURATION
# ----------------------------------

# 1. Obtenez un token de test:
#    Google: https://developers.google.com/oauthplayground/
#    Facebook: https://developers.facebook.com/tools/explorer/

# 2. Testez avec cURL:
#    curl -X POST http://localhost:8000/api/auth/social/login \
#      -H "Content-Type: application/json" \
#      -d '{"provider":"google","access_token":"VOTRE_TOKEN_DE_TEST"}'

# 3. Si ça fonctionne, vous devriez recevoir:
#    - success: true
#    - user: {...}
#    - token: "1|xxxxxx"

# ----------------------------------
# RESSOURCES
# ----------------------------------

# Documentation complète: SOCIAL_AUTH_FLUTTER_GUIDE.md
# Référence rapide: SOCIAL_AUTH_README.md
# Collection Postman: POSTMAN_SOCIAL_AUTH.md
